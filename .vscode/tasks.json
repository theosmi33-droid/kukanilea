{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "KUKANILEA: VS Code Guardrails (Auto-Fix)",
      "type": "shell",
      "command": "bash scripts/dev/vscode_guardrails.sh --apply --install-hooks",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "runOptions": {
        "runOn": "folderOpen"
      },
      "presentation": {
        "reveal": "never",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "KUKANILEA: VS Code Guardrails (Check)",
      "type": "shell",
      "command": "bash scripts/dev/vscode_guardrails.sh --check",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "KUKANILEA: Ready Check (Gemini + Runtime)",
      "type": "shell",
      "command": "OLLAMA_ENABLED=1 KUKANILEA_REMOTE_LLM_ENABLED=0 bash scripts/vscode_ready_check.sh",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "KUKANILEA: Pytest (all)",
      "type": "shell",
      "command": "pytest -q",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "KUKANILEA: Ruff Check",
      "type": "shell",
      "command": "ruff check .",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "KUKANILEA: Start App (127.0.0.1:5051)",
      "type": "shell",
      "command": "${config:python.defaultInterpreterPath} kukanilea_app.py --host 127.0.0.1 --port 5051",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "pattern": {
          "regexp": ".*"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "System ready\\.|Serving on",
          "endsPattern": "Serving on"
        }
      }
    },
    {
      "label": "KUKANILEA: GitHub PR Checks (current)",
      "type": "shell",
      "command": "gh pr checks --watch",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "KUKANILEA: Shared Memory Init",
      "type": "shell",
      "command": "${config:python.defaultInterpreterPath} scripts/shared_memory.py init",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "KUKANILEA: Shared Memory Read",
      "type": "shell",
      "command": "${config:python.defaultInterpreterPath} scripts/shared_memory.py read",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "KUKANILEA: Shared Memory Snapshot",
      "type": "shell",
      "command": "${config:python.defaultInterpreterPath} scripts/shared_memory.py snapshot --output docs/shared_memory_snapshot.json",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "KUKANILEA: AI Quick Start",
      "type": "shell",
      "command": "bash scripts/ai/quick_start_cli.sh",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "KUKANILEA: Gemini Fleet Kickoff (Parallel)",
      "type": "shell",
      "command": "bash scripts/orchestration/start_gemini_fleet.sh",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "KUKANILEA: Gemini Fleet Kickoff (Serial)",
      "type": "shell",
      "command": "bash scripts/orchestration/run_gemini_kickoff_serial.sh",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "KUKANILEA: Gemini Batch Compliance",
      "type": "shell",
      "command": "${config:python.defaultInterpreterPath} scripts/ai/batch_compliance_check.py",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "KUKANILEA: Stop Ollama",
      "type": "shell",
      "command": "pkill -f 'ollama serve' || true",
      "problemMatcher": []
    }
  ]
}
