diff --git a/app/static/css/components.css b/app/static/css/components.css
index b505edb..6bb602f 100644
--- a/app/static/css/components.css
+++ b/app/static/css/components.css
@@ -204,3 +204,291 @@
 .nav-link:hover {
   background: var(--color-bg-panel-hover);
 }
+
+/* Floating Chatbot Widget */
+.floating-chat-widget {
+  position: fixed;
+  right: 20px;
+  bottom: 20px;
+  z-index: 1200;
+  display: flex;
+  flex-direction: column;
+  align-items: flex-end;
+  gap: 10px;
+}
+
+.floating-chat-toggle {
+  position: relative;
+  width: 58px;
+  height: 58px;
+  border: 0;
+  border-radius: 999px;
+  cursor: pointer;
+  color: #fff;
+  background: linear-gradient(140deg, var(--color-primary), #3b82f6);
+  box-shadow: var(--shadow-lg);
+  font-weight: 700;
+}
+
+.floating-chat-toggle-label {
+  font-size: 15px;
+  letter-spacing: 0.02em;
+}
+
+.floating-chat-unread-badge {
+  position: absolute;
+  top: -4px;
+  right: -2px;
+  min-width: 18px;
+  height: 18px;
+  border-radius: 10px;
+  background: #ef4444;
+  color: #fff;
+  font-size: 11px;
+  line-height: 18px;
+  text-align: center;
+  padding: 0 4px;
+}
+
+.floating-chat-panel {
+  width: 380px;
+  height: 540px;
+  max-width: calc(100vw - 22px);
+  max-height: calc(100vh - 90px);
+  resize: both;
+  overflow: hidden;
+  display: flex;
+  flex-direction: column;
+  border: 1px solid var(--color-border);
+  border-radius: 16px;
+  background: var(--bg-primary);
+  box-shadow: var(--shadow-xl);
+}
+
+.floating-chat-panel.is-minimized {
+  height: auto;
+  resize: horizontal;
+  min-height: 0;
+}
+
+.floating-chat-header {
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  gap: 10px;
+  padding: 10px 12px;
+  border-bottom: 1px solid var(--color-border);
+  background: color-mix(in srgb, var(--bg-secondary) 70%, transparent);
+}
+
+.floating-chat-title-wrap {
+  min-width: 0;
+}
+
+.floating-chat-title {
+  margin: 0;
+  font-size: 14px;
+}
+
+.floating-chat-status {
+  margin: 2px 0 0;
+  font-size: 11px;
+  color: var(--text-secondary);
+}
+
+.floating-chat-controls {
+  display: flex;
+  align-items: center;
+  gap: 6px;
+}
+
+.floating-chat-icon-btn {
+  width: 28px;
+  height: 28px;
+  border: 1px solid var(--color-border);
+  border-radius: 8px;
+  background: transparent;
+  color: var(--text-primary);
+  cursor: pointer;
+}
+
+.floating-chat-context-tag {
+  padding: 8px 12px;
+  border-bottom: 1px solid var(--color-border);
+  font-size: 11px;
+  color: var(--text-secondary);
+}
+
+.floating-chat-quick-actions {
+  display: flex;
+  gap: 6px;
+  padding: 8px 10px;
+  overflow-x: auto;
+  border-bottom: 1px solid var(--color-border);
+}
+
+.floating-chat-quick-action {
+  white-space: nowrap;
+  height: 28px;
+  padding: 0 10px;
+}
+
+.floating-chat-body {
+  flex: 1;
+  min-height: 0;
+  overflow-y: auto;
+  padding: 10px 10px 6px;
+}
+
+.floating-chat-messages {
+  list-style: none;
+  margin: 0;
+  padding: 0;
+  display: flex;
+  flex-direction: column;
+  gap: 8px;
+}
+
+.floating-chat-msg {
+  display: flex;
+  flex-direction: column;
+  gap: 4px;
+}
+
+.floating-chat-msg-user {
+  align-items: flex-end;
+}
+
+.floating-chat-msg-assistant {
+  align-items: flex-start;
+}
+
+.floating-chat-bubble {
+  max-width: 88%;
+  padding: 8px 10px;
+  border-radius: 12px;
+  line-height: 1.4;
+  font-size: 13px;
+  border: 1px solid var(--color-border);
+}
+
+.floating-chat-msg-user .floating-chat-bubble {
+  color: #fff;
+  border-color: transparent;
+  background: var(--color-primary);
+}
+
+.floating-chat-msg-assistant .floating-chat-bubble {
+  color: var(--text-primary);
+  background: var(--bg-secondary);
+}
+
+.floating-chat-meta {
+  font-size: 10px;
+  color: var(--text-tertiary);
+}
+
+.floating-chat-thinking {
+  margin-top: 8px;
+  display: inline-flex;
+  align-items: center;
+  gap: 8px;
+  font-size: 12px;
+  color: var(--text-secondary);
+}
+
+.floating-chat-thinking-dot {
+  width: 8px;
+  height: 8px;
+  border-radius: 999px;
+  background: var(--color-primary);
+  animation: floating-chat-pulse 1s ease-in-out infinite;
+}
+
+.floating-chat-steps {
+  margin: 10px 0 0;
+  padding-left: 16px;
+  font-size: 11px;
+  color: var(--text-secondary);
+}
+
+.floating-chat-confirm {
+  margin: 0 10px 8px;
+  padding: 10px;
+  border: 1px solid var(--color-border);
+  border-radius: 12px;
+  background: var(--bg-secondary);
+}
+
+.floating-chat-confirm p {
+  margin: 0;
+  font-size: 12px;
+}
+
+.floating-chat-confirm-actions {
+  display: flex;
+  gap: 8px;
+  margin-top: 8px;
+}
+
+.floating-chat-form {
+  display: flex;
+  gap: 8px;
+  padding: 10px;
+  border-top: 1px solid var(--color-border);
+  background: color-mix(in srgb, var(--bg-secondary) 45%, transparent);
+}
+
+.floating-chat-form input {
+  flex: 1;
+  min-width: 0;
+  height: 34px;
+  border-radius: 10px;
+  border: 1px solid var(--color-border);
+  background: var(--bg-primary);
+  color: var(--text-primary);
+  padding: 0 10px;
+}
+
+.floating-chat-widget.is-weak-hw .floating-chat-thinking-dot {
+  animation: none;
+}
+
+@media (max-width: 760px) {
+  .floating-chat-widget {
+    right: 12px;
+    bottom: 12px;
+  }
+  .floating-chat-panel {
+    width: min(92vw, 420px);
+    height: min(74vh, 620px);
+    resize: none;
+  }
+}
+
+@media (prefers-reduced-motion: reduce) {
+  .floating-chat-toggle,
+  .floating-chat-panel,
+  .floating-chat-thinking-dot {
+    animation: none !important;
+    transition: none !important;
+  }
+}
+
+@keyframes floating-chat-pulse {
+  0% { transform: scale(0.92); opacity: 0.45; }
+  50% { transform: scale(1); opacity: 1; }
+  100% { transform: scale(0.92); opacity: 0.45; }
+}
+
+.sr-only {
+  position: absolute;
+  width: 1px;
+  height: 1px;
+  padding: 0;
+  margin: -1px;
+  overflow: hidden;
+  clip: rect(0, 0, 0, 0);
+  white-space: nowrap;
+  border: 0;
+}
