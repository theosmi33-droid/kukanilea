+    def _minimal_pdf_bytes(lines: List[str]) -> bytes:
+        safe_lines = [str(x or "").replace("\\", "\\\\").replace("(", "\\(").replace(")", "\\)") for x in lines[:80]]
+        content_parts = ["BT", "/F1 10 Tf", "50 790 Td"]
+        first = True
