+def _read_csv_grid(fp: Path) -> Tuple[List[List[str]], str]:
+    raw = None
+    used_enc = "utf-8"
+    for enc in ("utf-8-sig", "utf-8", "latin1"):
+        try:
+            raw = fp.read_text(encoding=enc, errors="strict")
+            used_enc = enc
+            break
+        except Exception:
+            continue
+    if raw is None:
+        raw = fp.read_text(encoding="utf-8", errors="ignore")
+        used_enc = "utf-8-ignore"
+
+    sio = io.StringIO(raw)
+    try:
+        sample = raw[:4096]
+        try:
+            dialect = csv.Sniffer().sniff(sample)
+        except Exception:
+            dialect = csv.excel
+        reader = csv.reader(sio, dialect)
+        grid: List[List[str]] = []
+        for r_i, row in enumerate(reader):
+            if r_i >= VISUALIZER_MAX_SHEET_ROWS:
+                break
+            vals = [normalize_component(x) for x in row[:VISUALIZER_MAX_SHEET_COLS]]
+            while vals and not vals[-1]:
+                vals.pop()
+            if vals:
+                grid.append(vals)
+        return grid, used_enc
+    except Exception:
+        lines = [normalize_component(x) for x in raw.splitlines()[:VISUALIZER_MAX_SHEET_ROWS]]
+        grid = [[line] for line in lines if line]
+        return grid, used_enc
+
+
+def _read_xlsx_grid(
+    fp: Path, sheet: str = ""
+) -> Tuple[str, List[str], List[List[str]]]:
+    if openpyxl is None:
+        fallback_text = _extract_xlsx_text(fp)
+        lines = [normalize_component(x) for x in fallback_text.splitlines() if x.strip()]
+        grid = [
+            [normalize_component(c) for c in ln.split("|")[:VISUALIZER_MAX_SHEET_COLS]]
+            for ln in lines[:VISUALIZER_MAX_SHEET_ROWS]
+        ]
+        return "Sheet1", ["Sheet1"], grid
+
+    wb = openpyxl.load_workbook(str(fp), read_only=True, data_only=True)
+    try:
+        sheet_names = [str(s) for s in wb.sheetnames]
+        if not sheet_names:
+            return "Sheet1", ["Sheet1"], []
+        active = sheet if sheet in sheet_names else sheet_names[0]
+        ws = wb[active]
+
+        grid: List[List[str]] = []
+        for r_i, row in enumerate(ws.iter_rows(values_only=True), start=1):
+            if r_i > VISUALIZER_MAX_SHEET_ROWS:
+                break
+            vals: List[str] = []
+            for c_i, val in enumerate(row[:VISUALIZER_MAX_SHEET_COLS], start=1):
+                if val is None:
+                    vals.append("")
+                    continue
+                sval = normalize_component(val)
+                vals.append(sval[:160])
+            while vals and not vals[-1]:
+                vals.pop()
+            if vals:
+                grid.append(vals)
+        return active, sheet_names, grid
+    finally:
+        try:
+            wb.close()
+        except Exception:
+            pass
+
+
+def _build_sheet_layers(
+    grid: List[List[str]], sheet_name: str, source_kind: str = "xlsx"
+) -> Dict[str, Any]:
+    row_count = len(grid)
+    col_count = max((len(r) for r in grid), default=0)
+    if row_count <= 0 or col_count <= 0:
+        return {"ocr": [], "meta": [{"label": "Leere Tabelle"}], "heat": []}
+
+    numeric_vals: List[float] = []
+    numeric_cells: List[Tuple[int, int, float]] = []
+    ocr_cells: List[Dict[str, Any]] = []
+    non_empty = 0
+    for r_i, row in enumerate(grid):
+        for c_i, val in enumerate(row):
+            if not val:
+                continue
+            non_empty += 1
+            ocr_cells.append(
+                {
+                    "x": round(c_i / col_count, 6),
+                    "y": round(r_i / row_count, 6),
+                    "w": round(1.0 / col_count, 6),
+                    "h": round(1.0 / row_count, 6),
+                    "text": val[:120],
+                    "confidence": 1.0,
+                    "source": "cell_text",
+                }
+            )
+            num = _number_from_token(val)
+            if num is not None:
+                numeric_vals.append(num)
+                numeric_cells.append((r_i, c_i, num))
+            if len(ocr_cells) >= VISUALIZER_MAX_WORDS:
+                break
+        if len(ocr_cells) >= VISUALIZER_MAX_WORDS:
+            break
+
+    heat: List[Dict[str, Any]] = []
+    if numeric_vals and numeric_cells:
+        lo = min(numeric_vals)
+        hi = max(numeric_vals)
+        span = hi - lo if hi != lo else 0.0
+        for r_i, c_i, num in numeric_cells[:VISUALIZER_MAX_WORDS]:
+            if span > 0:
+                score = (num - lo) / span
+            else:
+                score = 0.5
+            score = max(0.0, min(1.0, float(score)))
+            heat.append(
+                {
+                    "row": r_i + 1,
+                    "col": c_i + 1,
+                    "score": round(math.pow(score, 0.72), 4),
+                }
+            )
+
+    density = (float(non_empty) / float(max(1, row_count * col_count))) * 100.0
+    meta = [
+        {"label": f"Sheet: {sheet_name}"},
+        {"label": f"Raster: {row_count}x{col_count}"},
+        {"label": f"Dichte: {density:.1f}%"},
+        {"label": f"Numerische Felder: {len(numeric_cells)}"},
+        {"label": f"Quelle: {source_kind.upper()}"},
+    ]
+    return {"ocr": ocr_cells, "meta": meta, "heat": heat}
+
+
+def _build_sheet_visualizer_payload(fp: Path, sheet: str = "") -> Dict[str, Any]:
+    ext = fp.suffix.lower()
+    if ext == ".csv":
+        grid, enc = _read_csv_grid(fp)
+        sheet_name = "CSV"
+        sheet_names = ["CSV"]
+        source_kind = f"csv/{enc}"
+    else:
+        sheet_name, sheet_names, grid = _read_xlsx_grid(fp, sheet=sheet)
+        source_kind = "xlsx"
+
+    layers = _build_sheet_layers(grid, sheet_name=sheet_name, source_kind=source_kind)
+    row_count = len(grid)
+    col_count = max((len(r) for r in grid), default=0)
+    return {
+        "kind": "sheet",
+        "file": _file_visual_meta(fp),
+        "sheet": {
+            "name": sheet_name,
+            "available": sheet_names,
+            "rows": row_count,
+            "cols": col_count,
+        },
+        "grid": grid,
+        "layers": layers,
+    }
+
+
+def _build_image_visualizer_payload(fp: Path, force_ocr: bool = False) -> Dict[str, Any]:
+    image_b64 = ""
+    width = 0
+    height = 0
+    if Image is not None:
+        try:
+            with Image.open(str(fp)) as img:
+                width, height = img.size
+            with open(fp, "rb") as f:
+                image_b64 = base64.b64encode(f.read()).decode("ascii")
+        except Exception:
+            image_b64 = ""
+    if not image_b64:
+        image_b64 = _generate_thumbnail_b64(fp)
+
+    ocr_text = _ocr_image(fp) if force_ocr else ""
+    ocr_lines = [normalize_component(x) for x in (ocr_text or "").splitlines() if normalize_component(x)]
+    return {
+        "kind": "image",
+        "file": _file_visual_meta(fp),
+        "image": {
+            "width": width,
+            "height": height,
+            "mime": "image/png" if fp.suffix.lower() == ".png" else "image/jpeg",
+            "image_b64": image_b64,
+        },
+        "layers": {
+            "meta": [
+                {"label": f"Bild: {fp.suffix.lower().lstrip('.').upper()}"},
+                {"label": f"OCR-Zeilen: {len(ocr_lines)}"},
+            ],
+            "ocr_lines": ocr_lines[:120],
+        },
+    }
+
+
+def _build_text_visualizer_payload(fp: Path, force_ocr: bool = False) -> Dict[str, Any]:
+    text, used_ocr = _extract_text(fp, force_ocr=force_ocr)
+    pages = max(1, math.ceil(len(text or "") / 2400))
+    return {
+        "kind": "text",
+        "file": _file_visual_meta(fp),
+        "text": {
+            "content": (text or "").strip(),
+            "char_count": len(text or ""),
+            "page_count_estimate": pages,
+            "used_ocr": bool(used_ocr),
+        },
+        "layers": {
+            "meta": [
+                {"label": f"Textlänge: {len(text or '')} Zeichen"},
+                {"label": f"Seiten~: {pages}"},
+                {"label": f"OCR: {'ja' if used_ocr else 'nein'}"},
+            ]
+        },
+    }
+
+
+def build_visualizer_payload(
+    src: Path, page: int = 0, sheet: str = "", force_ocr: bool = False
+) -> Dict[str, Any]:
+    """
+    Build a compact, cacheable payload for the Forensic Eye visualizer.
+    """
+    fp = Path(src)
+    if not fp.exists():
+        raise FileNotFoundError(str(fp))
+    ext = fp.suffix.lower()
+    if ext not in (
+        ".pdf",
+        ".xlsx",
+        ".csv",
+        ".docx",
+        ".pptx",
+        ".txt",
+        ".md",
+        ".rtf",
+        ".json",
+        ".xml",
+        ".html",
+        ".htm",
+        ".eml",
+        ".msg",
+        ".jpg",
+        ".jpeg",
+        ".png",
+        ".tif",
+        ".tiff",
+        ".bmp",
+        ".webp",
+    ):
+        raise ValueError(f"Unsupported visualizer type: {ext}")
+
+    key = _visualizer_cache_key(fp, ext, page=page, sheet=sheet, force_ocr=force_ocr)
+    t0 = time.perf_counter()
+    cached = _visualizer_cache_get(key)
+    if cached is not None:
+        out = dict(cached)
+        perf = dict(out.get("perf", {}))
+        perf["cache_hit"] = True
+        perf["server_ms"] = round((time.perf_counter() - t0) * 1000.0, 2)
+        out["perf"] = perf
+        return out
+
+    if ext == ".pdf":
+        out = _build_pdf_visualizer_payload(fp, page=page, force_ocr=force_ocr)
+    elif ext in (".xlsx", ".csv"):
+        out = _build_sheet_visualizer_payload(fp, sheet=sheet)
+    elif ext in (".jpg", ".jpeg", ".png", ".tif", ".tiff", ".bmp", ".webp"):
+        out = _build_image_visualizer_payload(fp, force_ocr=force_ocr)
+    else:
+        out = _build_text_visualizer_payload(fp, force_ocr=force_ocr)
+
+    perf = dict(out.get("perf", {}))
+    perf["cache_hit"] = False
+    perf["server_ms"] = round((time.perf_counter() - t0) * 1000.0, 2)
+    out["perf"] = perf
+    _visualizer_cache_set(key, out)
+    return out
+
