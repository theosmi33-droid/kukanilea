+def _build_pdf_visualizer_payload(
+    fp: Path, page: int = 0, force_ocr: bool = False
+) -> Dict[str, Any]:
+    if fitz is None:
+        raise RuntimeError("PyMuPDF ist nicht verfügbar.")
+
+    with fitz.open(str(fp)) as doc:
+        page_count = max(1, len(doc))
+        page_idx = max(0, min(int(page), page_count - 1))
+        pg = doc.load_page(page_idx)
+
+        # Balanced: strong readability while staying responsive.
+        pix = pg.get_pixmap(matrix=fitz.Matrix(1.18, 1.18), alpha=False)
+        image_b64 = base64.b64encode(pix.tobytes("png")).decode("ascii")
+
+        page_w = float(pg.rect.width or 0.0)
+        page_h = float(pg.rect.height or 0.0)
+        ocr_layer = _pdf_text_layer(pg, page_w, page_h)
+        source = "embedded"
+        if (force_ocr or not ocr_layer) and page_w > 0 and page_h > 0:
+            fallback = _pdf_ocr_layer(pg, page_w, page_h)
+            if fallback:
+                ocr_layer = fallback
+                source = "ocr"
+
+        md = doc.metadata or {}
+        doc_meta: List[Dict[str, str]] = []
+        for k in (
+            "title",
+            "author",
+            "subject",
+            "keywords",
+            "creator",
+            "producer",
+            "creationDate",
+            "modDate",
+        ):
+            val = normalize_component(md.get(k, ""))
+            if val:
+                doc_meta.append({"key": k, "value": val[:240]})
+
+        return {
+            "kind": "pdf",
+            "file": _file_visual_meta(fp),
+            "page": {
+                "index": page_idx,
+                "count": page_count,
+                "width": round(page_w, 2),
+                "height": round(page_h, 2),
+                "image_b64": image_b64,
+            },
+            "layers": {
+                "ocr": ocr_layer,
+                "meta": _pdf_meta_badges(page_idx, page_count, len(ocr_layer), source),
+                "doc_meta": doc_meta,
+            },
+        }
+
