+def _decode_data_url_png(data_url: str) -> bytes:
+    s = normalize_component(data_url)
+    if not s:
+        return b""
+    marker = "base64,"
+    idx = s.find(marker)
+    if idx >= 0:
+        s = s[idx + len(marker) :]
+    try:
+        return base64.b64decode(s, validate=False)
+    except Exception:
+        return b""
