+def _visualizer_cache_key(
+    fp: Path, ext: str, page: int = 0, sheet: str = "", force_ocr: bool = False
+) -> str:
+    try:
+        st = fp.stat()
+        stamp = f"{st.st_mtime_ns}:{st.st_size}"
+    except Exception:
+        stamp = "0:0"
+    return (
+        f"{str(fp.resolve())}|{stamp}|{ext}|{int(page)}|"
+        f"{normalize_component(sheet)}|{1 if force_ocr else 0}"
+    )
+
+
+def _visualizer_cache_get(key: str) -> Optional[Dict[str, Any]]:
+    with _VISUALIZER_CACHE_LOCK:
+        item = _VISUALIZER_CACHE.get(key)
+        if item is None:
+            return None
+        try:
+            _VISUALIZER_CACHE_ORDER.remove(key)
+        except ValueError:
+            pass
+        _VISUALIZER_CACHE_ORDER.append(key)
+        return item
+
+
+def _visualizer_cache_set(key: str, payload: Dict[str, Any]) -> None:
+    with _VISUALIZER_CACHE_LOCK:
+        _VISUALIZER_CACHE[key] = payload
+        try:
+            _VISUALIZER_CACHE_ORDER.remove(key)
+        except ValueError:
+            pass
+        _VISUALIZER_CACHE_ORDER.append(key)
+        while len(_VISUALIZER_CACHE_ORDER) > VISUALIZER_MAX_CACHE_ITEMS:
+            oldest = _VISUALIZER_CACHE_ORDER.pop(0)
+            _VISUALIZER_CACHE.pop(oldest, None)
+
+
+def _file_visual_meta(fp: Path) -> Dict[str, Any]:
+    stat_size = 0
+    mtime = ""
+    try:
+        st = fp.stat()
+        stat_size = int(st.st_size)
+        mtime = datetime.fromtimestamp(st.st_mtime).isoformat(timespec="seconds")
+    except Exception:
+        pass
+    return {
+        "path": str(fp),
+        "name": fp.name,
+        "ext": fp.suffix.lower(),
+        "size": stat_size,
+        "updated_at": mtime,
+    }
+
+
+def _normalized_box(
+    x0: float, y0: float, x1: float, y1: float, width: float, height: float
+) -> Dict[str, float]:
+    if width <= 0 or height <= 0:
+        return {"x": 0.0, "y": 0.0, "w": 0.0, "h": 0.0}
+    x = max(0.0, min(float(x0) / width, 1.0))
+    y = max(0.0, min(float(y0) / height, 1.0))
+    w = max(0.0, min(float(x1 - x0) / width, 1.0))
+    h = max(0.0, min(float(y1 - y0) / height, 1.0))
+    return {
+        "x": round(x, 6),
+        "y": round(y, 6),
+        "w": round(w, 6),
+        "h": round(h, 6),
+    }
+
+
+def _number_from_token(token: str) -> Optional[float]:
+    s = normalize_component(token)
+    if not s:
+        return None
+    c = s.replace("\u00A0", " ").replace(" ", "")
+    c = c.replace("%", "").replace("EUR", "").replace("€", "")
+    if c.count(",") == 1 and c.count(".") >= 1:
+        if c.rfind(",") > c.rfind("."):
+            c = c.replace(".", "").replace(",", ".")
+        else:
+            c = c.replace(",", "")
+    elif c.count(",") == 1 and c.count(".") == 0:
+        c = c.replace(",", ".")
+    else:
+        c = c.replace(",", "")
+    c = re.sub(r"[^0-9+\-eE.]", "", c)
+    if not c or c in ("+", "-", ".", "+.", "-."):
+        return None
+    try:
+        return float(c)
+    except Exception:
+        return None
+
+
+def _pdf_text_layer(
+    page: Any, page_w: float, page_h: float, max_words: int = VISUALIZER_MAX_WORDS
+) -> List[Dict[str, Any]]:
+    words: List[Dict[str, Any]] = []
+    try:
+        raw_words = page.get_text("words") or []
+    except Exception:
+        raw_words = []
+
+    for row in raw_words[: max_words * 2]:
+        if len(row) < 5:
+            continue
+        x0, y0, x1, y1, txt = row[:5]
+        text = normalize_component(txt)
+        if not text:
+            continue
+        words.append(
+            {
+                **_normalized_box(float(x0), float(y0), float(x1), float(y1), page_w, page_h),
+                "text": text[:120],
+                "confidence": 1.0,
+                "source": "pdf_text",
+            }
+        )
+        if len(words) >= max_words:
+            break
+    return words
+
+
+def _pdf_ocr_layer(page: Any, page_w: float, page_h: float) -> List[Dict[str, Any]]:
+    if pytesseract is None or Image is None:
+        return []
+    out_type = getattr(getattr(pytesseract, "Output", None), "DICT", None)
+    if out_type is None:
+        return []
+    try:
+        pix = page.get_pixmap(dpi=170, alpha=False)
+        img = Image.open(io.BytesIO(pix.tobytes("png")))
+        data = pytesseract.image_to_data(
+            img, lang="deu+eng", output_type=out_type
+        )
+        iw, ih = img.size
+        if iw <= 0 or ih <= 0:
+            return []
+        sx = page_w / float(iw)
+        sy = page_h / float(ih)
+        texts = data.get("text", []) if isinstance(data, dict) else []
+        confs = data.get("conf", []) if isinstance(data, dict) else []
+        lefts = data.get("left", []) if isinstance(data, dict) else []
+        tops = data.get("top", []) if isinstance(data, dict) else []
+        widths = data.get("width", []) if isinstance(data, dict) else []
+        heights = data.get("height", []) if isinstance(data, dict) else []
+        out: List[Dict[str, Any]] = []
+        n = min(len(texts), len(confs), len(lefts), len(tops), len(widths), len(heights))
+        for i in range(n):
+            text = normalize_component(texts[i])
+            if not text:
+                continue
+            try:
+                conf = float(confs[i])
+            except Exception:
+                conf = -1.0
+            if conf >= 0 and conf < 35.0:
+                continue
+            x0 = float(lefts[i]) * sx
+            y0 = float(tops[i]) * sy
+            x1 = x0 + (float(widths[i]) * sx)
+            y1 = y0 + (float(heights[i]) * sy)
+            out.append(
+                {
+                    **_normalized_box(x0, y0, x1, y1, page_w, page_h),
+                    "text": text[:120],
+                    "confidence": round(max(0.0, min(100.0, conf)) / 100.0, 3),
+                    "source": "tesseract",
+                }
+            )
+            if len(out) >= VISUALIZER_MAX_WORDS:
+                break
+        return out
+    except Exception:
+        return []
+
+
+def _pdf_meta_badges(
+    page_no: int, page_count: int, ocr_words: int, source: str
+) -> List[Dict[str, Any]]:
+    labels = [
+        f"Seite {page_no + 1}/{page_count}",
+        f"Layer: {source}",
+        f"Tokens: {ocr_words}",
+    ]
+    out: List[Dict[str, Any]] = []
+    y = 0.02
+    for label in labels:
+        out.append({"x": 0.015, "y": round(y, 4), "label": label})
+        y += 0.038
+    return out
+
