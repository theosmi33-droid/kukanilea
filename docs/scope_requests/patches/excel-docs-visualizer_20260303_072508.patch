+    chart_png = str(payload.get("chart_png", "") or "")
+
+    try:
+        render_payload = build_visualizer_payload(  # type: ignore[misc]
+            fp, page=page, sheet=sheet, force_ocr=force_ocr
+        )
+        pdf_bytes = _build_visualizer_export_pdf_bytes(
