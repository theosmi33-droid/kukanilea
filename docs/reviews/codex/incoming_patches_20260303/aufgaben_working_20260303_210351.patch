+def task_delegate(task_id: str, *, new_assigned_user: str, delegated_by: str = "") -> bool:
+    """Assign or reassign a task to another user and emit an audit + outbound notification.
+
+    This is a domain-local helper used by UI and automation rules. It updates
+    the `assigned_user` column on `tasks` and records an audit entry. It will
+    attempt to enqueue an outbound notification but will not fail if the
+    outbound queue is not available in this environment.
+    """
+    new_assigned_user = normalize_component(new_assigned_user).lower()
+    delegated_by = normalize_component(delegated_by).lower()
+    if not new_assigned_user:
+        return False
+
+    with _DB_LOCK:
+        con = _db()
+        try:
+            row = con.execute("SELECT id, title, assigned_user FROM tasks WHERE id=?", (str(task_id),)).fetchone()
+            if not row:
+                return False
+            con.execute("UPDATE tasks SET assigned_user=? WHERE id=?", (new_assigned_user, str(task_id)))
+            con.commit()
+
+            # audit
+            try:
+                meta = json.dumps({"old_assigned": row["assigned_user"], "new_assigned": new_assigned_user}, ensure_ascii=False)
+                ts_now = _now_iso()
+                con.execute(
+                    "INSERT INTO audit_log(ts, tenant_id, username, action, resource, details) VALUES (?,?,?,?,?,?)",
+                    (ts_now, "", delegated_by or "system", "TASK_DELEGATE", str(task_id), meta),
+                )
+                con.commit()
+            except Exception:
+                pass
+
+            # best-effort outbound notification
+            try:
+                payload = json.dumps({
+                    "task_id": str(task_id),
+                    "title": row["title"],
+                    "assigned_user": new_assigned_user,
+                    "delegated_by": delegated_by,
+                }, ensure_ascii=False)
+                con.execute(
+                    "INSERT INTO api_outbound_queue(id, tenant_id, target_system, payload, status, retry_count, created_at) VALUES (?,?,?,?,?,?,?)",
+                    (str(uuid.uuid4()), "", "assignment", payload, "pending", 0, _now_iso()),
+                )
+                con.commit()
+            except Exception:
+                # ignore if table missing or insert fails
+                pass
+
+            return True
+        finally:
+            con.close()
+
+
