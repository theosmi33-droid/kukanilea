+def _parse_ics_trigger(raw: str | None) -> timedelta | None:
+    """Parse an iCalendar TRIGGER duration string into a timedelta.
+
+    Only a very small subset of the full RFC 5545 duration syntax is
+    supported.  We recognise things like ``-P1D`` (one day before the event)
+    and ``-PT15M`` (fifteen minutes before).  A leading ``-`` is taken to mean
+    "before" the DTSTART, so the returned timedelta is always positive and
+    should be subtracted from the event start if you want the absolute
+    reminder time.
+
+    Returns ``None`` for anything we cannot interpret.
+    """
+
+    token = (raw or "").strip()
+    if not token:
+        return None
+
+    # sign handling
+    negative = False
+    if token.startswith("-"):
+        negative = True
+        token = token[1:]
+    elif token.startswith("+"):
+        token = token[1:]
+
+    # simple PnDTnHnM grammar, ignore weeks/months/years
+    if not token.startswith("P"):
+        return None
+    token = token[1:]
+
+    days = 0
+    hours = 0
+    minutes = 0
+
+    # split date and time parts
+    if "T" in token:
+        date_part, time_part = token.split("T", 1)
+    else:
+        date_part, time_part = token, ""
+
+    m = re.search(r"(\d+)D", date_part)
+    if m:
+        days = int(m.group(1))
+
+    m = re.search(r"(\d+)H", time_part)
+    if m:
+        hours = int(m.group(1))
+
+    m = re.search(r"(\d+)M", time_part)
+    if m:
+        minutes = int(m.group(1))
+
+    if days == 0 and hours == 0 and minutes == 0:
+        return None
+
+    delta = timedelta(days=days, hours=hours, minutes=minutes)
+    # we want a positive offset for a negative trigger (i.e. before the event)
+    if negative:
+        return delta
+    # positive triggers (after) are not used for reminders in our world
+    return None
+
+
