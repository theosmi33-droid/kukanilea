{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kukanilea.local/schemas/tool_actions_list.schema.json",
  "title": "Tool Actions List Response",
  "type": "object",
  "required": ["tool", "contract_version", "actions"],
  "properties": {
    "tool": { "type": "string", "minLength": 1 },
    "contract_version": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "actions": {
      "type": "array",
      "items": { "$ref": "#/$defs/actionDescriptor" }
    }
  },
  "$defs": {
    "actionDescriptor": {
      "type": "object",
      "required": [
        "name",
        "title",
        "input_schema",
        "output_schema",
        "permissions",
        "confirm_gate",
        "idempotent"
      ],
      "properties": {
        "name": { "type": "string", "pattern": "^[a-z][a-z0-9_]{2,63}$" },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "input_schema": { "type": "object" },
        "output_schema": { "type": "object" },
        "permissions": { "$ref": "#/$defs/permissions" },
        "confirm_gate": { "$ref": "#/$defs/confirmGatePolicy" },
        "idempotent": { "type": "boolean", "const": true }
      },
      "additionalProperties": false
    },
    "permissions": {
      "type": "object",
      "required": ["resource", "operation", "roles_any"],
      "properties": {
        "resource": { "type": "string", "minLength": 1 },
        "operation": {
          "type": "string",
          "enum": ["read", "write", "delete", "execute", "admin"]
        },
        "roles_any": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "roles_all": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "conditions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["type"],
            "properties": {
              "type": { "type": "string" },
              "value": {}
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": false
    },
    "confirmGatePolicy": {
      "type": "object",
      "required": ["mode"],
      "properties": {
        "mode": { "type": "string", "enum": ["none", "required"] },
        "ttl_seconds": { "type": "integer", "minimum": 30, "maximum": 3600 }
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": { "properties": { "mode": { "const": "required" } } },
          "then": { "required": ["ttl_seconds"] }
        }
      ]
    }
  },
  "additionalProperties": false
}
