{
  "name": "New lead triage",
  "description": "Creates follow-up when a new lead event arrives.",
  "enabled": true,
  "max_executions_per_minute": 20,
  "triggers": [
    {
      "type": "eventlog",
      "config": {
        "allowed_event_types": [
          "lead.created"
        ]
      }
    }
  ],
  "conditions": [
    {
      "type": "match_context",
      "config": {
        "all": [
          {
            "field": "tenant_id",
            "equals": "KUKANILEA"
          },
          {
            "field": "lead_id",
            "present": true
          }
        ]
      }
    }
  ],
  "actions": [
    {
      "type": "create_task",
      "config": {
        "title": "Lead follow-up {{lead_id}}",
        "requires_confirm": false
      }
    }
  ]
}
